  <worldbody>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!--
      Tune the wall here:
      - `pos`: wall center in world coordinates (x y z)
      - `euler`: wall rotation in radians
      - `size`: half extents of the box (half_thickness half_length half_height)
    -->
    <body name="wall" pos="0 1.5 1.0" euler="0.0 0.0 1.5708">
      <geom
        name="wall_collision"
        type="box"
        size="0.05 1.0 1.0"
        material="wall_material"
        contype="1"
        conaffinity="1"
        friction="1.0 0.1 0.1"
        rgba="0.7 0.4 0.3 1"
      />
    </body>
  </worldbody>

